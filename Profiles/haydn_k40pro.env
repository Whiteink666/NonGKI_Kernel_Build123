DEVICE_NAME=Redmi_K40_Pro
DEVICE_CODENAME=haydn

KERNEL_SOURCE=https://github.com/MiCode/Xiaomi_Kernel_OpenSource.git
KERNEL_BRANCH=haydn-t-oss

DEFCONFIG_NAME=haydn_defconfig

CLANG_SOURCE=https://github.com/LineageOS/android_prebuilts_clang_host_linux-x86.git
CLANG_BRANCH=lineage-21.0

GCC_GNU=true

KERNELSU_SOURCE=https://github.com/SukiSU-Ultra/SukiSU-Ultra.git
KERNELSU_BRANCH=main
KERNELSU_NAME=SukiSU

SUSFS_ENABLE=true
SUSFS_FIXED=true

AK3_SOURCE=https://github.com/osm0sis/AnyKernel3.git
AK3_BRANCH=master

PACK_METHOD=Anykernel3
KERNELSU_METHOD=shell
